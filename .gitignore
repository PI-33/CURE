optimization/temp_data/
optimization/ckpt/

# Logs
logs/


# Test results
test_results/

# Evaluation and optimization results
evaluation/results/
optimization/results/

# Data files (too large for git)
data/*.json

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Torch extensions cache
*.so
*.o

# Experiment outputs (large checkpoints, tb logs, eval artifacts)
# Per-run HF checkpoint copies live at experiments/<name>/ckpt/<optimized_model_name>/
experiments/*/ckpt/
experiments/*/optimization/ckpt/
experiments/*/optimization/tb_logs/
experiments/*/evaluation/
experiments/*/train.log

# Model weight blobs (HF shards, PyTorch, etc.) anywhere under CURE
**/*.safetensors
**/*.pt
**/*.pth
**/*.ckpt
**/*.gguf
**/pytorch_model*.bin

# Evaluation temp data
evaluation/temp_data/
